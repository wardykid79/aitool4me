{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "www.aitool4me.com"}],
      "destination": "https://aitool4me.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Robots-Tag", "value": "index, follow"}
      ]
    }
  ]
}
